# SEC fair access policy requires a descriptive User-Agent containing a contact email.
# Replace before deploying. Example: "Investment Seeker contact@example.com"
SEC_USER_AGENT_EMAIL=your-email@example.com

# Anthropic API key (for /api/summarize)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (for caching filing summaries)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
